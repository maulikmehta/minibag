# === SESSIONS SDK - LOCAL POSTGRESQL (via Postgres.app) ===
# The Sessions SDK uses a separate PostgreSQL database
# Make sure Postgres.app is running
DATABASE_URL=postgresql://localhost:5432/sessions_test?schema=public

# JWT - Test secrets (not production!)
JWT_SECRET=test-secret-key-for-testing-only
JWT_EXPIRES_IN=1d

# SMS API - Mock for testing
SMS_API_KEY=test_key
SMS_API_URL=http://localhost:9999/mock-sms

# API & WebSocket - Test server
API_PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Frontend - Local test API
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Razorpay - Test mode keys
RAZORPAY_KEY_ID=test_razorpay_key
RAZORPAY_KEY_SECRET=test_razorpay_secret

# Encryption - Test key
ENCRYPTION_KEY=test_encryption_key_32_chars_long_1234567890abcdef

# Sentry - Disabled for tests
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=test
SENTRY_DSN=
SENTRY_ENVIRONMENT=test

# Sessions SDK Integration - Enabled for testing
USE_SESSIONS_SDK=true
DUAL_WRITE_MODE=false
ENABLE_GROUP_MODE=true

# Test-specific flags
VITEST_LOG_DB=false  # Set to true to log database connections during tests
