{
  "name": "@localloops/minibag",
  "version": "2.0.0",
  "description": "Minibag - Vegetable vendor coordination app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "dependencies": {
    "@localloops/ui-components": "*",
    "chart.js": "^4.5.1",
    "driver.js": "^1.3.6",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.0",
    "react-router-dom": "^6.30.1",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@size-limit/file": "^11.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "rollup-plugin-visualizer": "^6.0.5",
    "size-limit": "^11.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.0",
    "vitest": "^1.2.1"
  },
  "size-limit": [
    {
      "name": "Total JS Bundle (gzipped)",
      "path": "dist/assets/*.js",
      "limit": "250 KB",
      "gzip": true
    },
    {
      "name": "Initial Load (main + vendor-react)",
      "path": [
        "dist/assets/minibag-ui-prototype-*.js",
        "dist/assets/vendor-react-*.js"
      ],
      "limit": "100 KB",
      "gzip": true
    },
    {
      "name": "CSS Bundle",
      "path": "dist/assets/*.css",
      "limit": "20 KB",
      "gzip": true
    }
  ]
}
