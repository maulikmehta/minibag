{
  "version": 2,
  "installCommand": "echo 'Skipping auto-install, handled in buildCommand'",
  "buildCommand": "npm install --prefix packages/minibag && cd packages/minibag && npx vite build",
  "outputDirectory": "packages/minibag/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
