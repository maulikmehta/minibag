# Production Environment Configuration
# Copy this to .env.production and fill in actual values
# NEVER commit .env.production to version control

# =============================================================================
# DEPLOYMENT TARGETS
# =============================================================================
# Frontend: Vercel (minibag.cc)
# Backend: Render.com
# Database: Supabase

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=production

# =============================================================================
# SUPABASE (Database + Auth)
# =============================================================================
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# JWT (Session Management)
# =============================================================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_string_here
JWT_EXPIRES_IN=30d

# =============================================================================
# ENCRYPTION
# =============================================================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_string_here

# =============================================================================
# SMS API (for OTP)
# =============================================================================
# Provider: Fast2SMS, Twilio, MSG91, etc.
SMS_API_KEY=your_sms_api_key_here
SMS_API_URL=https://api.your-sms-provider.com/send

# =============================================================================
# RAZORPAY (Payments)
# =============================================================================
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# =============================================================================
# ADMIN AUTHENTICATION
# =============================================================================
# Change from default! Use strong password (16+ chars)
ADMIN_PASSWORD=your_secure_admin_password_here

# =============================================================================
# API & WEBSOCKET PORTS
# =============================================================================
# Render.com automatically assigns PORT
PORT=3000
WEBSOCKET_PORT=3001
API_PORT=3000

# =============================================================================
# FRONTEND URL (for CORS)
# =============================================================================
FRONTEND_URL=https://minibag.cc

# =============================================================================
# BACKEND URLs (for Vercel frontend env)
# =============================================================================
# Update these in Vercel dashboard after Render deployment
# Prefix with VITE_ for frontend environment variables
VITE_API_URL=https://minibag-backend-xxxxx.onrender.com
VITE_WS_URL=https://minibag-backend-xxxxx.onrender.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable Sessions SDK for session management (default: false for safety)
USE_SESSIONS_SDK=false

# Dual-write mode: write to both old and new systems (default: false)
DUAL_WRITE_MODE=false

# Enable group mode with constant invite links (default: true)
ENABLE_GROUP_MODE=true

# =============================================================================
# ERROR TRACKING (Optional)
# =============================================================================
# Sentry DSN (if using Sentry for error tracking)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =============================================================================
# RATE LIMITING
# =============================================================================
# Max requests per window (default: 100)
RATE_LIMIT_MAX=100

# Time window in minutes (default: 15)
RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# SESSION SETTINGS
# =============================================================================
# Session expiry hours after scheduled time (default: 2)
SESSION_EXPIRY_HOURS=2

# Max participants per session (default: 50)
MAX_PARTICIPANTS=50

# =============================================================================
# NOTES
# =============================================================================
# 1. Generate strong secrets using crypto.randomBytes()
# 2. Never commit this file with real values
# 3. Use Vercel/Render dashboards to set env vars
# 4. Prefix frontend vars with VITE_
# 5. Update FRONTEND_URL after domain setup
# 6. Update VITE_API_URL after Render deployment
